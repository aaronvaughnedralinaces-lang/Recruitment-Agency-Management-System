# Frontend Environment Variables (for Vite - must start with VITE_)
# This is the API base URL the frontend will use
# For local development: http://localhost:5000/api
# For production (Railway): https://your-railway-backend-url.up.railway.app/api
VITE_API_URL=http://localhost:5000/api

# Backend Environment Variables (set in Railway Dashboard for production)
# These variables are used by the Node.js/Express backend server
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=rams_db
JWT_SECRET=your_super_secret_key_change_in_production
PORT=5000
NODE_ENV=development
